[
  {
    "scenario": "Valid Login",
    "email": "bimlaesh@gmail.com",
    "password": "123456bky",
    "is_valid": true,
    "expected_message": ""
  },
  {
    "scenario": "Invalid Password",
    "email": "bimlaesh@gmail.com",
    "password": "wrong_password_xyz",
    "is_valid": false,
    "error_type": "page",
    "expected_message": "Your email or password is incorrect!"
  },
  {
    "scenario": "Only Password Empty",
    "email": "bimlaesh@gmail.com",
    "password": "",
    "is_valid": false,
    "error_type": "browser",
    "error_element": "#password",
    "expected_message": "Please fill out this field."
  },
  {
    "scenario": "Invalid Email Format",
    "email": "hhhh",
    "password": "password123",
    "is_valid": false,
    "error_type": "browser",
    "error_element": "#email",
    "expected_message": "Please include an '@' in the email address. 'hhhh' is missing an '@'."
  }
]
